model User {
     id String @id @default(uuid())
     name String 
     email String @unique
     password String
     activeStatus ActiveStatus @default(ACTIVE)
     role Role @default(USER)
     profile Profile?
     createdAt DateTime @default(now())
     updatedAt DateTime @updatedAt


     posts Post[]
     comments Comment[]

     @@map("user")
}


enum ActiveStatus {
    ACTIVE
    INACTIVE
    BLOCKED
}
 enum Role {
    USER
    AUTHOR
    ADMIN
}

