model User {
     id String @id @default(uuid())
     name String 
     email String @unique
     password String
     activeStatus ActiveStatus @default(ACTIVE)
     role Role @default(USER)
     profile Profile?
     createdAt DateTime @default(now())
     updatedAt DateTime @updatedAt
     @@map("user")
}


enum ActiveStatus {
    ACTIVE
    INACTIVE
}
 enum Role {
    USER
    AUTHOR
}

